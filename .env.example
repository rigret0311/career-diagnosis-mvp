# 実メール送信を有効にする場合は、このファイルを .env にコピーして設定してください。

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-account@example.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=your-account@example.com
SMTP_FROM_NAME=キャリア市場価値診断
REPLY_TO_EMAIL=your-account@example.com

# メール内クリック計測URLのベースです。未設定なら http://127.0.0.1:5000 を使います。
APP_BASE_URL=http://127.0.0.1:5000
